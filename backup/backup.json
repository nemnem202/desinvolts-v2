				"postId": null,
				"trombinoscopeItemId": null,
				"groupPageFirstId": 1,
				"groupPageSecondId": null,
				"dateId": null,
				"paragraph": {
					"id": 33,
					"content": "Desinvolts est un groupe de rock dynamique, d'origine tourangelle, ayant vu le jour en 2020.",
					"hyperlinks": []
				}
			}
		],
		"second_section_paragraphs": [
			{
				"paragraphId": 25,
				"position": 6,
				"eventId": null,
				"albumId": null,
				"postId": null,
				"trombinoscopeItemId": null,
				"groupPageFirstId": null,
				"groupPageSecondId": 1,
				"dateId": null,
				"paragraph": {
					"id": 25,
					"content": "En mars 2021, l’album “Volt-Face” sort sur toutes les plateformes musicales avec 11 de leurs titres originaux.",
					"hyperlinks": []
				}
			},
			{
				"paragraphId": 26,
				"position": 5,
				"eventId": null,
				"albumId": null,
				"postId": null,
				"trombinoscopeItemId": null,
				"groupPageFirstId": null,
				"groupPageSecondId": 1,
				"dateId": null,
				"paragraph": {
					"id": 26,
					"content": "En 2020, les amis annoncent leur nouveau nom : Desinvolts. Ce nom reprend un code plus français, une attitude rock présente dans leurs chansons.",
					"hyperlinks": []
				}
			},
			{
				"paragraphId": 27,
				"position": 4,
				"eventId": null,
				"albumId": null,
				"postId": null,
				"trombinoscopeItemId": null,
				"groupPageFirstId": null,
				"groupPageSecondId": 1,
				"dateId": null,
				"paragraph": {
					"id": 27,
					"content": "En 2019, le groupe décide de faire un album de leurs compositions en français. L’enregistrement met plus de temps que prévu avec les événements de 2020.",
					"hyperlinks": []
				}
			},
			{
				"paragraphId": 28,
				"position": 3,
				"eventId": null,
				"albumId": null,
				"postId": null,
				"trombinoscopeItemId": null,
				"groupPageFirstId": null,
				"groupPageSecondId": 1,
				"dateId": null,
				"paragraph": {
					"id": 28,
					"content": "Brice et Franck veulent écrire exclusivement des textes en français. Au fil des années, le groupe étoffe son repertoire dans un style rock dynamique.",
					"hyperlinks": []
				}
			},
			{
				"paragraphId": 29,
				"position": 2,
				"eventId": null,
				"albumId": null,
				"postId": null,
				"trombinoscopeItemId": null,
				"groupPageFirstId": null,
				"groupPageSecondId": 1,
				"dateId": null,
				"paragraph": {
					"id": 29,
					"content": "En 2015, un EP de 5 titres, “Switch on” sert à la promotion du groupe.",
					"hyperlinks": []
				}
			},
			{
				"paragraphId": 30,
				"position": 1,
				"eventId": null,
				"albumId": null,
				"postId": null,
				"trombinoscopeItemId": null,
				"groupPageFirstId": null,
				"groupPageSecondId": 1,
				"dateId": null,
				"paragraph": {
					"id": 30,
					"content": "En avril 2014, Brice rejoint le groupe au chant. Les 5 membres sillonnent la région tourangelle pour mettre l’ambiance dans les bars et sur les scènes de villages.",
					"hyperlinks": []
				}
			},
			{
				"paragraphId": 31,
				"position": 0,
				"eventId": null,
				"albumId": null,
				"postId": null,
				"trombinoscopeItemId": null,
				"groupPageFirstId": null,
				"groupPageSecondId": 1,
				"dateId": null,
				"paragraph": {
					"id": 31,
					"content": "L’histoire se passe à Tours (37). Le groupe se forme en février 2012 sous l’impulsion de Franck, batteur. Eric à la basse, Laurent et Rui aux guitares répondent à l’appel.",
					"hyperlinks": []
				}
			}
		],
